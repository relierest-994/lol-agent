# Provider mode
VITE_APP_ENV=dev
VITE_APP_PROVIDER_MODE=real
VITE_APP_ALLOW_MOCK_FALLBACK=true
VITE_USE_BACKEND_API=true

# Frontend shell should only call backend API
VITE_API_BASE_URL=http://localhost:8080
VITE_REQUEST_TIMEOUT_MS=12000
VITE_REQUEST_RETRIES=1

# Backend app env
APP_ENV=dev
APP_PROVIDER_MODE=real
APP_ALLOW_MOCK_FALLBACK=true
APP_USE_BACKEND_API=true

# Queue runtime mode: http | local
APP_QUEUE_RUNTIME_MODE=local

# Storage mode: local | object
APP_VIDEO_STORAGE_MODE=local

# Backend LLM (text)
LLM_ENABLED=true
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=

# Backend multimodal provider
VIDEO_API_URL=http://localhost:8080/providers/video-diagnosis
VIDEO_API_KEY=
VIDEO_LLM_MODEL=gpt-4.1-mini

# Backend storage
STORAGE_API_URL=http://localhost:8080/storage
STORAGE_BUCKET=lol-agent-stage

# Backend queue
QUEUE_API_URL=http://localhost:8080/queue
QUEUE_NAME=video_diagnosis

# Backend payment
PAYMENT_PROVIDER=STRIPE
PAYMENT_WEBHOOK_SECRET=
PAYMENT_API_URL=http://localhost:8080/payments
PAYMENT_API_KEY=

# Game provider auth (backend only)
RIOT_PROVIDER_ENABLED=false
RIOT_API_BASE_URL=https://kr.api.riotgames.com
RIOT_API_KEY=
WEGAME_PROVIDER_ENABLED=false
WEGAME_OAUTH_AUTH_URL=
WEGAME_OAUTH_TOKEN_URL=
WEGAME_OAUTH_PROFILE_URL=
WEGAME_OAUTH_CLIENT_ID=
WEGAME_OAUTH_CLIENT_SECRET=
WEGAME_OAUTH_REDIRECT_URI=

# Backend PG16 (server-side only, do NOT expose with VITE_*)
APP_DB_DIALECT=postgres
APP_DB_VERSION=16
APP_DB_HOST=127.0.0.1
APP_DB_PORT=5432
APP_DB_NAME=lol_agent
APP_DB_USER=lol_agent
APP_DB_PASSWORD=
APP_DB_SSL_MODE=disable
APP_DB_POOL_MIN=2
APP_DB_POOL_MAX=20
